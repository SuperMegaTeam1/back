{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Jwt": {
    "Key": "YOUR_SECRET_KEY",
    "Issuer": "Backend",
    "Audience": "BackendClient",
    "ExpireMinutes": 60
  },

  "AllowedHosts": "*"
}